<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <!-- Task Image -->
    <ImageView
        android:id="@+id/taskListImage"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:layout_marginEnd="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Task Title -->
    <TextView
        android:id="@+id/taskTitleView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Task Title"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/taskListImage"
        app:layout_constraintTop_toTopOf="@id/taskListImage"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Task Description -->
    <TextView
        android:id="@+id/taskListDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Task description goes here"
        android:textSize="14sp"
        android:layout_marginTop="6dp"
        app:layout_constraintStart_toStartOf="@id/taskTitleView"
        app:layout_constraintTop_toBottomOf="@id/taskTitleView"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
